#include <stdio.h>
#include <string.h>

// Definição do número de estados e alfabeto
#define NUM_ESTADOS 3
#define TAM_ALFABETO 2

int main() {
    // Tabela de Transição [EstadoAtual][Entrada] = ProximoEstado
    // Entradas: '0' -> índice 0, '1' -> índice 1
    int transicao[NUM_ESTADOS][TAM_ALFABETO] = {
        {1, 0}, // Estado 0 (q0): '0' vai para q1, '1' vai para q0
        {1, 2}, // Estado 1 (q1): '0' vai para q1, '1' vai para q2
        {1, 0}  // Estado 2 (q2): '0' vai para q1, '1' vai para q0
    };

    int estadoFinal = 2; // q2 é o estado de aceitação
    int estadoAtual = 0; // Estado inicial
    char cadeia[100];

    printf("Digite a cadeia (0s e 1s): ");
    scanf("%s", cadeia);

    for (int i = 0; i < strlen(cadeia); i++) {
        int simbolo = cadeia[i] - '0'; // Converte '0'/'1' para 0/1
        
        // Verifica se é símbolo válido
        if (simbolo != 0 && simbolo != 1) {
            printf("Símbolo inválido!\n");
            return 1;
        }
        
        estadoAtual = transicao[estadoAtual][simbolo];
    }

    if (estadoAtual == estadoFinal)
        printf("Cadeia Aceita\n");
    else
        printf("Cadeia Rejeitada\n");

    return 0;
}

